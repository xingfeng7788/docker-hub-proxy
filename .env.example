# ==========================================
# Docker Hub Proxy - Environment Variables
# ==========================================

# ------------------------------------------
# Server Configuration
# ------------------------------------------
# 监听地址 (默认: 0.0.0.0)
HOST=0.0.0.0

# 监听端口 (默认: 8000)
PORT=8000

# 上游代理请求超时时间（秒） (默认: 10.0)
PROXY_TIMEOUT=10.0

# ------------------------------------------
# 搜索代理配置
# ------------------------------------------
# 如果你的服务器在国内，无法直接访问 hub.docker.com 导致搜索超时，
# 可以配置一个 HTTP/SOCKS 代理地址专供搜索功能使用（仅影响搜索，不影响拉取测速）
# 示例: SEARCH_PROXY=http://127.0.0.1:7890
SEARCH_PROXY=


# ------------------------------------------
# Security & Authentication (Phase 1)
# ------------------------------------------
# Web UI 控制台的登录凭证
# 如果这两项留空或不配置，Web UI 将保持公开访问，不要求登录。
ADMIN_USER=admin
ADMIN_PASS=admin


# ------------------------------------------
# Access Control (Phase 2)
# ------------------------------------------
# IP 白名单 (多个 IP 用逗号分隔)
# 如果配置了此项，只有名单中的 IP 可以通过此服务拉取镜像。留空则允许所有 IP。
# 示例: IP_WHITELIST=127.0.0.1,192.168.1.100
IP_WHITELIST=

# 镜像拉取白名单 (基于正则表达式)
# 如果配置了此项，仅允许拉取匹配正则的镜像。留空则不限制。
# 示例: 仅允许拉取官方 library 镜像 -> IMAGE_WHITELIST_REGEX=^library/
IMAGE_WHITELIST_REGEX=

# 镜像拉取黑名单 (基于正则表达式)
# 如果配置了此项，匹配正则的镜像将被禁止拉取。优先级高于白名单。留空则不限制。
# 示例: 禁止拉取带有 google 或 gcr.io 相关的镜像 -> IMAGE_BLACKLIST_REGEX=(google|gcr\.io)
IMAGE_BLACKLIST_REGEX=
